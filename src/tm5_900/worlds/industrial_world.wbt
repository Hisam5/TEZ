WorldInfo {
  info [
    "Techman TM5-900 arm industrial environment with conveyors and crates."
    "Robot support block is visual only, so the URDF robot will not get stuck inside it."
  ]
  title "TM5-900 Industrial Cell"
  basicTimeStep 8
  physicsDisableAngularThreshold 0.1
  contactProperties [
    ContactProperties {
      bounce 0.1
    }
    ContactProperties {
      material1 "slope"
      coulombFriction [
        0.5
      ]
    }
  ]
}

