}

# -----------------------------------------------------------------------------
# VISUAL SUPPORT UNDER THE ROBOT — NO COLLISION
# -----------------------------------------------------------------------------
# This support block is made with Transform, not Solid.
# Therefore it has NO boundingObject and it will NOT collide with the robot.
#
# Use this robot spawn pose in your ROS 2 URDFSpawner:
#
#   translation='0.00 0.00 1.00'
#   rotation='0 0 1 0'
#
# If the robot is still slightly low, increase only the robot Z value:
#   0.95 / 1.00 / 1.05
# -----------------------------------------------------------------------------

DEF ROBOT_BASE_PEDESTAL Transform {
  translation 0.00 0.00 0.30
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.55 0.55 0.55
        roughness 0.45
        metalness 0.2
      }
      geometry Box {
        size 0.75 0.75 0.60
      }
    }
  ]
}

DEF ROBOT_TOP_PLATE Transform {
  translation 0.00 0.00 0.62
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.18 0.18 0.18
        roughness 0.35
        metalness 0.6
      }
      geometry Cylinder {
        radius 0.30
        height 0.03
      }
    }
  ]
}
