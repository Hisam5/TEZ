        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://ur16/meshes/l1.STL" />
            </geometry>
        </collision>
    </link>

    <joint name="j0" type="revolute">
        <origin xyz="0 0 0.0637" rpy="1.5708 0 -0.27865" />
        <parent link="base_link" />
        <child link="l1" />
        <axis xyz="0 1 0" />
        <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14" />
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="l2">
        <inertial>
            <origin xyz="-0.2145 0.13338 2.9099E-06" rpy="0 0 0" />
            <mass value="1.5858" />
            <inertia ixx="0.0056431" ixy="-4.2324E-07" ixz="-8.3606E-08" iyy="0.008282" iyz="1.2335E-08" izz="0.0097323" />
