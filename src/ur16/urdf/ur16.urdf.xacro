<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ur16">

    <link name="world"/> 

    <joint name="world_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://ur16/meshes/base_link.STL" />
            </geometry>
            <material name="">
                <color rgba="0.50196 0.50196 0.50196 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://ur16/meshes/base_link.STL" />
            </geometry>
        </collision>
    </link>

    <link name="l1">
        <inertial>
            <origin xyz="-0.0046617 0.064919 -2.9765E-05" rpy="0 0 0" />
            <mass value="0.60391" />
            <inertia ixx="0.002353" ixy="5.4163E-05" ixz="1.5509E-07" iyy="0.0015823" iyz="1.3637E-06" izz="0.0023074" />
        </inertial>
        <visual>
