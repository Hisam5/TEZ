<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ur16">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import ur16 urdf file -->
    <xacro:include filename="$(find ur16)/urdf/ur16.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="ur16.ros2_control.xacro" />


    <xacro:ur16_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
